---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/BirdSwarmHero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import AnimatedStats from '../components/AnimatedStats';

const services = [
  {
    title: 'Web Development',
    description: 'Modern, performant web applications built with React, Vue.js, and TypeScript. Optimized for speed and SEO.',
    icon: 'web',
    link: '/services#web-development'
  },
  {
    title: 'AI Automation',
    description: 'Intelligent automation systems using OpenAI, Anthropic, and Google Gemini APIs to reduce manual work by 60-90% and improve accuracy.',
    icon: 'ai',
    link: '/services#ai-integration'
  },
  {
    title: 'WordPress Development',
    description: 'Custom WordPress builds, headless setups, and managed security and maintenance for agencies and business owners.',
    icon: 'support',
    link: '/services/wordpress'
  },
  {
    title: 'Design & Motion',
    description: 'Brand and UI design plus motion design: explainer animations, product motion, and social/marketing motion. Led by Katlyn.',
    icon: 'design',
    link: '/services#design'
  },
  {
    title: 'E-commerce Solutions',
    description: 'Custom online stores with automated affiliate marketing, SEO optimization, and payment processing achieving 4x industry conversion rates.',
    icon: 'ecommerce',
    link: '/services#ecommerce'
  }
];

const projects = [
  {
    title: 'RecycleOldTech.com',
    category: 'E-commerce / SEO',
    image: 'https://images.pexels.com/photos/5632402/pexels-photo-5632402.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=2',
    link: 'https://recycleoldtech.com'
  },
  {
    title: 'DowntownDry',
    category: 'AI Integration',
    image: 'https://images.pexels.com/photos/8386434/pexels-photo-8386434.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=2',
    link: 'https://downtowndry.com'
  },
  {
    title: 'IndiAide RTM System',
    category: 'Healthcare Tech',
    image: 'https://images.pexels.com/photos/8106498/pexels-photo-8106498.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=2',
    link: '/work#indiaide'
  },
  {
    title: 'EdReports Platform Migration',
    category: 'Full-Stack Development',
    image: 'https://images.pexels.com/photos/5473302/pexels-photo-5473302.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=2',
    link: 'https://edreports.org'
  }
];
---

<Layout
  title="AI Automation, Full-Stack Development & Design"
  description="Creative Bandit is a two-person studio pairing AI automation and full-stack development with design and motion. 8+ years experience with React, Vue.js, TypeScript, and modern AI APIs. WordPress development and managed care. Based in Indianapolis, serving clients nationwide."
  keywords="AI automation consultant, full-stack developer, design and motion studio, React Vue.js TypeScript, workflow automation, HIPAA compliant web development, OpenAI integration, Indianapolis developer, WordPress development, WordPress maintenance, headless WordPress"
>
  <Hero />

  <!-- Services Section -->
  <section class="section bg-dark-200">
    <div class="container mx-auto">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <div class="mb-4 flex items-center justify-center">
          <span class="flame-dot"></span>
          <span class="uppercase tracking-wider text-light-300">Our Services</span>
        </div>
        <h2 class="mb-6">Services That <span class="gradient-text">Get Results</span></h2>
        <p class="text-light-300">Web development, AI automation, WordPress, design and motion, and e-commerce under one roof. Built to reduce manual work and move real business metrics.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {services.map(service => (
          <ServiceCard
            title={service.title}
            description={service.description}
            icon={service.icon}
            link={service.link}
          />
        ))}
      </div>

      <div class="mt-12 text-center">
        <a href="/services" class="btn-secondary">Explore All Services</a>
      </div>
    </div>
  </section>

  <!-- About Us Section -->
  <section class="section relative overflow-hidden">
    <div class="container mx-auto relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <div class="mb-6 flex items-center">
            <span class="flame-dot"></span>
            <span class="uppercase tracking-wider text-light-300">About Creative Bandit</span>
          </div>
          <h2 class="mb-6">Full-Stack Development + <span class="gradient-text">Design That Delivers Results</span></h2>
          <p class="text-light-300 mb-6">
            We're Creative Bandit, a two-person studio pairing development with design. Adam brings 8+ years of full-stack and AI automation experience, including healthcare technology work at Eli Lilly, HIPAA-compliant systems for Medicare billing, and platforms at Salesforce serving thousands of users. Katlyn leads design and motion, bringing brand and UI work to life with animation.
          </p>
          <p class="text-light-300 mb-8">
            Together we build intelligent systems and interfaces that reduce manual work by 60-90% while looking and moving the way a modern brand should. Recent projects include AI-powered verification systems achieving 100% accuracy and automated marketing pipelines processing 1,000+ monthly transactions.
          </p>
          <div class="grid grid-cols-2 gap-6">
            <div>
              <h4 class="font-bold text-lg mb-2 text-flameTip">AI Automation</h4>
              <p class="text-light-300 text-sm">Intelligent systems using GPT, Claude, and Gemini APIs to eliminate manual work and improve accuracy.</p>
            </div>
            <div>
              <h4 class="font-bold text-lg mb-2 text-coreFire">Design & Motion</h4>
              <p class="text-light-300 text-sm">Brand, UI, and motion design that makes interfaces feel as good as they function.</p>
            </div>
          </div>
        </div>
        <div class="relative">
          <div class="about-card-glow rounded-lg p-8 border border-coreFire/20 bg-dark-100/80 backdrop-blur-sm">
            <h3 class="text-xl font-bold mb-6">Why Choose Creative Bandit?</h3>
            <ul class="space-y-4">
              <li class="flex items-start">
                <span class="w-2 h-2 bg-flameTip rounded-full mt-2 mr-3 flex-shrink-0"></span>
                <span class="text-light-300">8+ years building production applications for Fortune 500 companies (Eli Lilly, Salesforce) and startups</span>
              </li>
              <li class="flex items-start">
                <span class="w-2 h-2 bg-coreFire rounded-full mt-2 mr-3 flex-shrink-0"></span>
                <span class="text-light-300">AI automation specialist reducing manual work by 60-90% through intelligent system design</span>
              </li>
              <li class="flex items-start">
                <span class="w-2 h-2 bg-blazingEmber rounded-full mt-2 mr-3 flex-shrink-0"></span>
                <span class="text-light-300">Proven track record: 100% accuracy AI verification, 8.08% affiliate conversion (4x industry average)</span>
              </li>
              <li class="flex items-start">
                <span class="w-2 h-2 bg-magentaFlame rounded-full mt-2 mr-3 flex-shrink-0"></span>
                <span class="text-light-300">Full-stack expertise from React/Vue/TypeScript frontend to Node.js/Python backend to AI API integration</span>
              </li>
              <li class="flex items-start">
                <span class="w-2 h-2 bg-flameTip rounded-full mt-2 mr-3 flex-shrink-0"></span>
                <span class="text-light-300">In-house design and motion: brand, UI, and animation work without an external agency handoff</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
    <!-- Subtle background accents -->
    <div class="absolute top-1/2 right-0 w-96 h-96 bg-coreFire/5 blur-3xl rounded-full -translate-y-1/2 translate-x-1/2"></div>
  </section>

  <!-- Results Section -->
  <section class="section relative overflow-hidden">
    <div class="container mx-auto relative z-10">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <div class="mb-4 flex items-center justify-center">
          <span class="flame-dot"></span>
          <span class="uppercase tracking-wider text-light-300">Real Results</span>
        </div>
        <h2 class="mb-6">Measurable <span class="gradient-text">Business Impact</span></h2>
        <p class="text-light-300">Concrete outcomes from real projects. Every metric represents actual production results, not projections.</p>
      </div>

      <div class="mb-16">
        <AnimatedStats client:only="react" />
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <div class="rounded-xl p-8 border border-flameTip/20 bg-gradient-to-br from-dark-100 to-dark-200">
          <h3 class="text-xl font-bold mb-6 text-flameTip">AI & Automation Wins</h3>
          <ul class="space-y-4">
            <li class="flex items-start">
              <span class="w-2 h-2 bg-flameTip rounded-full mt-2 mr-3 flex-shrink-0"></span>
              <span class="text-light-300">DowntownDry: 100% accuracy venue verification using Gemini AI + Google APIs</span>
            </li>
            <li class="flex items-start">
              <span class="w-2 h-2 bg-flameTip rounded-full mt-2 mr-3 flex-shrink-0"></span>
              <span class="text-light-300">RecycleOldTech: 1,000+ monthly referrals through automated content pipeline</span>
            </li>
            <li class="flex items-start">
              <span class="w-2 h-2 bg-flameTip rounded-full mt-2 mr-3 flex-shrink-0"></span>
              <span class="text-light-300">IndiAide: HIPAA-compliant automation for Medicare RTM billing compliance</span>
            </li>
            <li class="flex items-start">
              <span class="w-2 h-2 bg-flameTip rounded-full mt-2 mr-3 flex-shrink-0"></span>
              <span class="text-light-300">AI-assisted development workflows reducing debugging time by 20%</span>
            </li>
          </ul>
        </div>

        <div class="rounded-xl p-8 border border-magentaFlame/20 bg-gradient-to-br from-dark-100 to-dark-200">
          <h3 class="text-xl font-bold mb-6 text-magentaFlame">Enterprise Achievements</h3>
          <ul class="space-y-4">
            <li class="flex items-start">
              <span class="w-2 h-2 bg-magentaFlame rounded-full mt-2 mr-3 flex-shrink-0"></span>
              <span class="text-light-300">Eli Lilly: Led Next.js migration and React design system transition</span>
            </li>
            <li class="flex items-start">
              <span class="w-2 h-2 bg-magentaFlame rounded-full mt-2 mr-3 flex-shrink-0"></span>
              <span class="text-light-300">Salesforce: API integration layer reducing manual data entry by 60%</span>
            </li>
            <li class="flex items-start">
              <span class="w-2 h-2 bg-magentaFlame rounded-full mt-2 mr-3 flex-shrink-0"></span>
              <span class="text-light-300">EdReports: 30% increase in developer productivity post-migration</span>
            </li>
            <li class="flex items-start">
              <span class="w-2 h-2 bg-magentaFlame rounded-full mt-2 mr-3 flex-shrink-0"></span>
              <span class="text-light-300">Design system adoption across 15+ engineers on pharmaceutical applications</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
    <!-- Background gradient mesh -->
    <div class="absolute inset-0 -z-10">
      <div class="absolute top-0 left-1/4 w-96 h-96 bg-flameTip/5 blur-3xl rounded-full"></div>
      <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-magentaFlame/5 blur-3xl rounded-full"></div>
    </div>
  </section>

  <!-- TODO: re-add lead-magnet checklist section once a real ConvertKit form + PDF exist -->

  <!-- Testimonials Section -->
  <section class="py-16 md:py-20 bg-dark-200 relative overflow-hidden">
    <div class="container mx-auto relative z-10">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <div class="mb-4 flex items-center justify-center">
          <span class="flame-dot"></span>
          <span class="uppercase tracking-wider text-light-300">What Clients Say</span>
        </div>
        <h2 class="mb-6">Trusted By <span class="gradient-text">Real Clients</span></h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        {/* TODO: replace with real client quotes */}
        <TestimonialCard
          quote="[TODO: gather a real client quote]"
          author="[TODO: name]"
          position="[TODO: title]"
          company="[TODO: company]"
        />
        <TestimonialCard
          quote="[TODO: gather a real client quote]"
          author="[TODO: name]"
          position="[TODO: title]"
          company="[TODO: company]"
        />
      </div>
    </div>
  </section>

  <!-- Projects Section -->
  <section class="section bg-dark-200">
    <div class="container mx-auto">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <div class="mb-4 flex items-center justify-center">
          <span class="flame-dot"></span>
          <span class="uppercase tracking-wider text-light-300">Featured Work</span>
        </div>
        <h2 class="mb-6">Real <span class="gradient-text">Projects</span> With Real Results</h2>
        <p class="text-light-300">A selection of production applications showcasing AI automation, full-stack development, and measurable business outcomes.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 gap-8">
        {projects.map(project => (
          <ProjectCard
            title={project.title}
            category={project.category}
            image={project.image}
            link={project.link}
          />
        ))}
      </div>

      <div class="mt-12 text-center">
        <a href="/work" class="btn-secondary">See More Projects</a>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-24 relative overflow-hidden">
    <div class="container mx-auto relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <div class="mb-6 flex items-center">
            <span class="flame-dot"></span>
            <span class="uppercase tracking-wider text-light-300">Get Started</span>
          </div>
          <h2 class="mb-6">Ready to Build <span class="gradient-text">AI-Powered Solutions</span> That Eliminate Manual Work?</h2>
          <p class="text-light-300 text-lg mb-8">
            Currently accepting select automation projects. Tell us how intelligent systems can reduce your manual work by 60-90% and deliver measurable business impact.
          </p>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8">
            <div class="flex items-center">
              <span class="w-3 h-3 bg-flameTip rounded-full mr-3"></span>
              <span class="text-light-300">Free 30-minute consultation</span>
            </div>
            <div class="flex items-center">
              <span class="w-3 h-3 bg-coreFire rounded-full mr-3"></span>
              <span class="text-light-300">Concrete project proposal</span>
            </div>
            <div class="flex items-center">
              <span class="w-3 h-3 bg-blazingEmber rounded-full mr-3"></span>
              <span class="text-light-300"><a href="/services#pricing" class="hover:text-blazingEmber transition-colors duration-300">Transparent pricing</a></span>
            </div>
            <div class="flex items-center">
              <span class="w-3 h-3 bg-magentaFlame rounded-full mr-3"></span>
              <span class="text-light-300">Modern, performant tech stack</span>
            </div>
          </div>
          <div class="flex flex-wrap gap-4">
            <a href="/contact" class="btn-primary">Book a Free Consultation</a>
            <a href="/services" class="btn-secondary">Explore Services</a>
          </div>
        </div>

        <div class="rounded-xl p-8 border border-coreFire/20 bg-dark-100/80 backdrop-blur-sm">
          <h3 class="text-xl font-bold mb-6">What You Get With Creative Bandit</h3>
          <div class="space-y-6">
            <div class="border-l-4 border-flameTip pl-4">
              <h4 class="font-bold text-lg mb-2">Enterprise Experience</h4>
              <p class="text-light-300 text-sm">8+ years building production applications for Fortune 500 companies including Eli Lilly and Salesforce.</p>
            </div>

            <div class="border-l-4 border-coreFire pl-4">
              <h4 class="font-bold text-lg mb-2">AI Automation Expertise</h4>
              <p class="text-light-300 text-sm">Proven results with OpenAI, Anthropic, and Google Gemini APIs. 100% accuracy verification, 90% time savings.</p>
            </div>

            <div class="border-l-4 border-blazingEmber pl-4">
              <h4 class="font-bold text-lg mb-2">Full-Stack Capability</h4>
              <p class="text-light-300 text-sm">React, Vue.js, TypeScript, Node.js, Python. Complete solutions from frontend to backend to deployment.</p>
            </div>

            <div class="border-l-4 border-flameTip pl-4">
              <h4 class="font-bold text-lg mb-2">Design & Motion In-House</h4>
              <p class="text-light-300 text-sm">Brand, UI, and motion design led by Katlyn. No external agency handoff required.</p>
            </div>

            <div class="border-l-4 border-magentaFlame pl-4">
              <h4 class="font-bold text-lg mb-2">Remote-First Collaboration</h4>
              <p class="text-light-300 text-sm">Async-first workflow with clear communication. Based in Indianapolis, serving clients nationwide.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
    <!-- Background gradient effects -->
    <div class="absolute inset-0 -z-10">
      <div class="absolute bottom-0 right-0 w-1/3 h-1/2 bg-blazingEmber/5 blur-3xl rounded-full"></div>
      <div class="absolute top-0 left-0 w-1/3 h-1/2 bg-magentaFlame/5 blur-3xl rounded-full"></div>
      <div class="absolute top-1/2 left-1/2 w-1/4 h-1/3 bg-coreFire/3 blur-3xl rounded-full -translate-x-1/2 -translate-y-1/2"></div>
    </div>
  </section>
</Layout>
