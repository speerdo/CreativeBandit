---
import Layout from '../../layouts/Layout.astro';

const included = [
  {
    title: 'Security header audits + automated fixes',
    description: 'Scan for missing/misconfigured security headers (CSP, HSTS, X-Frame-Options, etc.) and automatically apply fixes where possible.'
  },
  {
    title: 'Plugin & core update monitoring',
    description: 'Track WordPress core, theme, and plugin versions across every client site and flag updates before they become a liability.'
  },
  {
    title: 'Uptime + broken link / mixed content scanning',
    description: 'Continuous uptime monitoring alongside scans for broken links and mixed-content (HTTP/HTTPS) issues that quietly hurt SEO and trust.'
  },
  {
    title: 'Weekly/monthly client-ready reports',
    description: 'Automated, white-label-ready reports you can hand straight to your clients — no manual compiling required.'
  }
];

// TODO: finalize pricing — likely tiered by site count (per-site/month or agency bundle)
const pricingTiers = [
  { name: 'Starter', sites: 'Up to 10 sites', price: '[TODO: $/mo]' },
  { name: 'Agency', sites: 'Up to 50 sites', price: '[TODO: $/mo]' },
  { name: 'Scale', sites: '50+ sites', price: '[TODO: Contact for bundle pricing]' }
];
---

<Layout title="Agent Ops — WordPress Security & Maintenance" description="Automated security, maintenance, and compliance monitoring for WordPress agencies and their clients. Currently onboarding pilot agencies.">
  <!-- Hero Section -->
  <section class="section pt-24 relative">
    <div class="container mx-auto">
      <div class="max-w-3xl">
        <div class="mb-6 flex items-center">
          <span class="flame-dot"></span>
          <span class="uppercase tracking-wider text-light-300">New — Currently Onboarding Pilot Agencies</span>
        </div>
        <h1 class="mb-6">Automated Security &amp; Maintenance Ops for <span class="gradient-text">WordPress Agencies</span></h1>
        <p class="text-xl text-light-300 mb-8">
          Agencies manage security, updates, and uptime across dozens of client sites by hand — a process that's slow and error-prone at scale. Agent Ops automates the monitoring and reporting so nothing falls through the cracks.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="/contact" class="btn-primary">Book a Free Audit</a>
          <a href="/services" class="btn-secondary">Back to Services</a>
        </div>
      </div>
    </div>

    <div class="absolute top-0 right-0 w-full h-full -z-10">
      <div class="absolute top-0 right-0 w-1/2 h-full bg-gradient-to-l from-blazingEmber/10 to-transparent opacity-30"></div>
    </div>
  </section>

  <!-- What's Included -->
  <section class="py-16">
    <div class="container mx-auto">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <div class="mb-4 flex items-center justify-center">
          <span class="flame-dot"></span>
          <span class="uppercase tracking-wider text-light-300">What's Included</span>
        </div>
        <h2 class="mb-6">Ops, <span class="gradient-text">Automated</span></h2>
        <p class="text-light-300">A draft feature set — refined as pilot agencies come on board.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {included.map(item => (
          <div class="card">
            <h3 class="text-xl font-bold mb-3">{item.title}</h3>
            <p class="text-light-300">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="section bg-dark-200">
    <div class="container mx-auto">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <div class="mb-4 flex items-center justify-center">
          <span class="flame-dot"></span>
          <span class="uppercase tracking-wider text-light-300">Pricing</span>
        </div>
        <h2 class="mb-6">Tiered by <span class="gradient-text">Site Count</span></h2>
        <p class="text-light-300">Pilot pricing — finalized as we onboard the first agencies. [TODO: confirm rates]</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {pricingTiers.map(tier => (
          <div class="card text-center">
            <h3 class="text-xl font-bold mb-2">{tier.name}</h3>
            <p class="text-light-300 mb-4">{tier.sites}</p>
            <p class="text-2xl font-bold gradient-text">{tier.price}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-24 relative overflow-hidden">
    <div class="container mx-auto relative z-10">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="mb-6">Managing Security Across <span class="gradient-text">Client Sites</span> Manually?</h2>
        <p class="text-light-300 text-lg mb-8">We're onboarding a small group of pilot agencies to shape Agent Ops around real workflows. Book a free audit to see where your client sites stand.</p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href="/contact" class="btn-primary">Book a Free Audit</a>
        </div>
      </div>
    </div>
    <div class="absolute top-0 right-0 w-full h-full -z-10">
      <div class="absolute bottom-0 right-0 w-1/3 h-1/2 bg-blazingEmber/5 blur-3xl rounded-full"></div>
      <div class="absolute top-0 left-0 w-1/3 h-1/2 bg-magentaFlame/5 blur-3xl rounded-full"></div>
    </div>
  </section>
</Layout>
